rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function validPublicProfile() {
      return request.resource.data.keys().hasOnly([
        'primeiroNome', 'segundoNome', 'nomeCompleto', 'fotoUrl',
        'cidade', 'ativo', 'criadoEm', 'atualizadoEm'
      ]);
    }

    function validCard() {
      return request.resource.data.keys().hasOnly([
        'nomeTitular', 'bandeira', 'ultimos4', 'validade', 'criadoEm'
      ])
      && request.resource.data.ultimos4 is string
      && request.resource.data.ultimos4.size() == 4;
    }

    function invitedByContact(data) {
      return signedIn()
        && 'conviteContatoKeys' in data
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && 'conviteContatoKey' in
          get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        && data.conviteContatoKeys.hasAny([
          get(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            .data.conviteContatoKey
        ]);
    }

    function canAccessMatch(data) {
      return signedIn() && (
        !('visibilidade' in data)
        || data.visibilidade == 'PUBLICA'
        || data.organizadorId == request.auth.uid
        || (
          'participantesUids' in data
          && data.participantesUids.hasAny([request.auth.uid])
        )
        || invitedByContact(data)
      );
    }

    function isCaptain(data, team) {
      return signedIn() && (
        (
          team == 'TIME_1'
          && 'capitaoTime1Uid' in data
          && data.capitaoTime1Uid == request.auth.uid
        )
        || (
          team == 'TIME_2'
          && 'capitaoTime2Uid' in data
          && data.capitaoTime2Uid == request.auth.uid
        )
      );
    }

    match /usuarios/{userId} {
      // Perfil privado: e-mail, telefone e endereço ficam visíveis só ao dono.
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.firebaseUid == request.auth.uid;
      allow delete: if false;
    }

    match /usuariosPublicos/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && validPublicProfile();
      allow delete: if false;
    }

    match /cartoes/{userId}/{document=**} {
      allow read, delete: if signedIn()
        && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && validCard();
    }

    match /configuracoes/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /estabelecimentos/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.criadoPor == request.auth.uid;
      allow update, delete: if false;
    }

    match /quadras/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /partidas/{partidaId} {
      allow read: if canAccessMatch(resource.data);
      // Só o próprio organizador cria a partida em seu nome.
      allow create: if signedIn()
        && request.resource.data.organizadorId == request.auth.uid
        && request.resource.data.visibilidade in ['PUBLICA', 'PRIVADA'];
      // Só o organizador altera a partida (status, placar, escalação).
      allow update: if signedIn() && (
        resource.data.organizadorId == request.auth.uid
        || (
          (
            resource.data.visibilidade == 'PUBLICA'
            || invitedByContact(resource.data)
          )
          && changedOnly(['participantesUids', 'atualizadoEm'])
          && request.resource.data.participantesUids.size()
            == resource.data.participantesUids.size() + 1
          && request.resource.data.participantesUids
            .hasAll(resource.data.participantesUids)
          && request.resource.data.participantesUids
            .hasAll([request.auth.uid])
        )
        || (
          changedOnly([
            'participantesUids', 'capitaoTime1Uid',
            'capitaoTime2Uid', 'atualizadoEm'
          ])
          && 'participantesUids' in resource.data
          && resource.data.participantesUids.hasAny([request.auth.uid])
          && !request.resource.data.participantesUids.hasAny([request.auth.uid])
          && resource.data.participantesUids.size()
            == request.resource.data.participantesUids.size() + 1
          && resource.data.participantesUids
            .hasAll(request.resource.data.participantesUids)
        )
        || (
          isCaptain(resource.data, 'TIME_1')
          && changedOnly(['formacaoTime1', 'atualizadoEm'])
        )
        || (
          isCaptain(resource.data, 'TIME_2')
          && changedOnly(['formacaoTime2', 'atualizadoEm'])
        )
      );
      allow delete: if false;

      match /membros/{membroId} {
        allow read: if canAccessMatch(
          get(/databases/$(database)/documents/partidas/$(partidaId)).data
        );
        // O organizador gerencia os membros; o próprio usuário pode entrar.
        // organizadorId é denormalizado no membro para evitar get() (que não
        // enxerga a partida criada no mesmo batch e ainda custa uma leitura).
        allow create: if signedIn() && (
          request.resource.data.organizadorId == request.auth.uid
          || (
            request.resource.data.usuarioId == request.auth.uid
            && (
              get(/databases/$(database)/documents/partidas/$(partidaId))
                .data.visibilidade == 'PUBLICA'
              || get(/databases/$(database)/documents/partidas/$(partidaId))
                .data.participantesUids.hasAny([request.auth.uid])
              || invitedByContact(
                get(/databases/$(database)/documents/partidas/$(partidaId)).data
              )
            )
          )
        );
        allow update: if signedIn() && (
          resource.data.organizadorId == request.auth.uid
          || (
            changedOnly(['posX', 'posY'])
            && isCaptain(
              get(/databases/$(database)/documents/partidas/$(partidaId)).data,
              resource.data.equipe
            )
          )
        );
        allow delete: if signedIn() && (
          resource.data.organizadorId == request.auth.uid
          || resource.data.usuarioId == request.auth.uid
        );
      }
    }

    // ---- Campeonatos (dados de demonstração compartilhados) ----
    match /clubes/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.donoId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.donoId == request.auth.uid;
      allow delete: if false;
    }

    match /clubeJogadores/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.donoId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.donoId == request.auth.uid;
    }

    match /ligas/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.donoId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.donoId == request.auth.uid;
      allow delete: if false;
    }

    match /ligaClubes/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.donoId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.donoId == request.auth.uid;
      allow update: if false;
    }

    match /confrontos/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.donoId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.donoId == request.auth.uid;
      allow delete: if false;
    }

    // ---- Goleiros ----
    match /goleiros/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /contratacoesGoleiro/{documentId} {
      allow read: if signedIn();
      // O solicitante cria a contratação em seu nome.
      allow create: if signedIn()
        && request.resource.data.solicitanteId == request.auth.uid;
      // O goleiro responde (aceita/recusa) às suas contratações.
      allow update: if signedIn()
        && resource.data.goleiroUid == request.auth.uid;
      allow delete: if false;
    }

    // ---- Social: amizades ----
    match /amizades/{documentId} {
      // Só os dois envolvidos leem/alteram a amizade.
      allow read: if signedIn()
        && request.auth.uid in resource.data.usuarios;
      allow create: if signedIn()
        && request.resource.data.solicitanteId == request.auth.uid
        && request.resource.data.status == 'PENDENTE'
        && request.resource.data.usuarios.size() == 2
        && request.resource.data.usuarios.hasAll([
          request.resource.data.solicitanteId,
          request.resource.data.destinatarioId
        ]);
      allow update: if signedIn()
        && request.auth.uid in resource.data.usuarios
        && (
          (
            changedOnly(['status', 'criadoEm'])
            && (
              (request.auth.uid == resource.data.destinatarioId
                && request.resource.data.status in ['ACEITO', 'RECUSADO'])
              || (request.auth.uid == resource.data.solicitanteId
                && request.resource.data.status == 'PENDENTE')
            )
          )
          || (
            changedOnly([
              'solicitanteId', 'destinatarioId', 'status',
              'criadoEm', 'atualizadoEm'
            ])
            && request.resource.data.status == 'PENDENTE'
            && request.resource.data.solicitanteId == request.auth.uid
            && request.resource.data.destinatarioId in resource.data.usuarios
            && request.resource.data.destinatarioId != request.auth.uid
            && request.resource.data.usuarios == resource.data.usuarios
          )
        );
      allow delete: if false;
    }

    // ---- Social: feed ----
    match /postagens/{postagemId} {
      allow read: if signedIn() && (
        !('visibilidade' in resource.data)
        || resource.data.visibilidade == 'PUBLICO'
        || resource.data.autorId == request.auth.uid
        || (
          'visivelPara' in resource.data
          && resource.data.visivelPara.hasAny([request.auth.uid])
        )
      );
      allow create: if signedIn()
        && request.resource.data.autorId == request.auth.uid
        && (
          !('visibilidade' in request.resource.data)
          || request.resource.data.visibilidade in ['PUBLICO', 'AMIGOS']
        );
      allow update: if signedIn() && (
        (
          changedOnly(['curtidoPor'])
          && (
            (
              request.resource.data.curtidoPor.size()
                == resource.data.curtidoPor.size() + 1
              && request.resource.data.curtidoPor
                .hasAll(resource.data.curtidoPor)
              && request.resource.data.curtidoPor
                .hasAll([request.auth.uid])
            )
            || (
              request.resource.data.curtidoPor.size() + 1
                == resource.data.curtidoPor.size()
              && resource.data.curtidoPor
                .hasAll(request.resource.data.curtidoPor)
              && resource.data.curtidoPor.hasAny([request.auth.uid])
              && !request.resource.data.curtidoPor.hasAny([request.auth.uid])
            )
          )
        )
        || (
          changedOnly(['comentariosCount'])
          && request.resource.data.comentariosCount
            == resource.data.comentariosCount + 1
        )
      );
      allow delete: if false;

      match /comentarios/{comentarioId} {
        allow read: if signedIn() && (
          !('visibilidade' in
            get(/databases/$(database)/documents/postagens/$(postagemId)).data)
          || get(/databases/$(database)/documents/postagens/$(postagemId))
              .data.visibilidade == 'PUBLICO'
          || get(/databases/$(database)/documents/postagens/$(postagemId))
              .data.autorId == request.auth.uid
          || (
            'visivelPara' in
              get(/databases/$(database)/documents/postagens/$(postagemId)).data
            && get(/databases/$(database)/documents/postagens/$(postagemId))
                .data.visivelPara.hasAny([request.auth.uid])
          )
        );
        allow create: if signedIn()
          && request.resource.data.autorId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ---- Rateio (divisão de custos) ----
    match /rateios/{documentId} {
      allow read: if signedIn()
        && resource.data.organizadorId == request.auth.uid;
      // Só o organizador da partida cria/recalcula/fecha o rateio.
      allow create: if signedIn()
        && request.resource.data.organizadorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.organizadorId == request.auth.uid;
      allow delete: if false;
    }

    match /cobrancas/{documentId} {
      allow read: if signedIn()
        && resource.data.organizadorId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.organizadorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.organizadorId == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
