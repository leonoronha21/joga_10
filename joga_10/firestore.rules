rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.firebaseUid == request.auth.uid;
      allow delete: if false;
    }

    match /configuracoes/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /estabelecimentos/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.criadoPor == request.auth.uid;
      allow update, delete: if false;
    }

    match /quadras/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /partidas/{partidaId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;

      match /membros/{membroId} {
        allow read: if signedIn();
        allow create, update: if signedIn();
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
